# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/

# production
/build

# environment files — never commit secrets
.env
.env.local
.env.*.local

# testing artifacts
/coverage
/test-reports
/playwright-report
/blob-report

# typescript build info
*.tsbuildinfo
next-env.d.ts

# prisma generated client
/src/generated/prisma

# misc
.DS_Store
*.pem
.vercel

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# large binary / installer files
*.deb
*.rpm
*.exe
*.dmg

# PWA generated service worker (built artifact)
/public/sw.js
/public/workbox-*.js
