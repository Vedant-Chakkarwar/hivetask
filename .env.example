# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hivetask

# Auth
JWT_SECRET=your-random-256-bit-secret-here
JWT_REFRESH_SECRET=your-random-256-bit-refresh-secret-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# AWS (for Phase 5)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=hivetask-attachments
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_KMS_KEY_ID=

# Security (for Phase 6)
E2E_ENABLED=false
SESSION_IDLE_TIMEOUT=900
SESSION_ABSOLUTE_TIMEOUT=28800
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AUTH=5
